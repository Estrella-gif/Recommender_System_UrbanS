# JWT — genera una clave segura con:
#   Linux/Mac: openssl rand -base64 64
#   Windows PS: [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=<generar-con-el-comando-de-arriba>

# FastAPI
IA_SERVICE_URL=http://localhost:8000
